{
  "buildCommand": "node -e \"const fs=require('fs');let sw=fs.readFileSync('sw.js','utf8');sw=sw.replace('BUILD_TIMESTAMP',new Date().toISOString());fs.writeFileSync('sw.js',sw);\"",
  "outputDirectory": ".",
  "crons": [{ "path": "/api/data?action=drift", "schedule": "0 0 * * *" }],
  "functions": {
    "api/leadgen-agent.js": { "maxDuration": 120 },
    "api/data.js":          { "maxDuration": 60 }
  }
}
